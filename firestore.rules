rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ── Helpers ───────────────────────────────────────── */
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function pairId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function validFriendshipPairDoc(pairDocId, memberIds) {
      return memberIds is list
        && memberIds.size() == 2
        && memberIds[0] is string
        && memberIds[1] is string
        && memberIds[0] != memberIds[1]
        && (
          pairDocId == memberIds[0] + '_' + memberIds[1]
          || pairDocId == memberIds[1] + '_' + memberIds[0]
        );
    }

    function validPendingInviteWrite(pairDocId) {
      return signedIn()
        && request.resource.data.keys().hasAll(['memberIds', 'invitedBy', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['memberIds', 'invitedBy', 'invitedByName', 'status', 'createdAt'])
        && validFriendshipPairDoc(pairDocId, request.resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending';
    }

    function friendshipActiveWith(targetUid) {
      let pid = pairId(request.auth.uid, targetUid);
      return exists(/databases/$(database)/documents/friendships/$(pid)) &&
        get(/databases/$(database)/documents/friendships/$(pid)).data.status == 'active';
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function validGroupDoc() {
      return request.resource.data.keys().hasAll(['name', 'memberIds', 'createdBy', 'activeChallengeIds'])
        && request.resource.data.keys().hasOnly(['name', 'memberIds', 'createdBy', 'activeChallengeIds', 'createdAt', 'updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() >= 2
        && request.resource.data.memberIds.size() <= 5
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.activeChallengeIds is list;
    }

    /* ── Future: teams / challenges (deny by default, expand later) ── */
    match /teams/{teamId} {
      allow read, write: if false;
    }
    match /teamMembers/{docId} {
      allow read, write: if false;
    }
    match /challenges/{challengeId} {
      allow read, write: if false;
    }
    match /leaderboards/{docId} {
      allow read, write: if false;
    }

    /* ── Accountability groups ─────────────────────────── */
    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() && validGroupDoc();
      allow update: if isGroupMember(groupId)
        && request.resource.data.keys().hasOnly(['name', 'memberIds', 'createdBy', 'activeChallengeIds', 'createdAt', 'updatedAt'])
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.name is string
        && request.resource.data.activeChallengeIds is list;
      allow delete: if false;

      match /promises/{memberUid} {
        allow read: if isGroupMember(groupId);
        allow write: if isGroupMember(groupId)
          && memberUid == request.auth.uid
          && request.resource.data.keys().hasOnly(['uid', 'text', 'updatedAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string;
      }

      match /checkIns/{checkInId} {
        allow read: if isGroupMember(groupId);
        allow create, update: if isGroupMember(groupId)
          && request.resource.data.keys().hasOnly(['uid', 'date', 'dailyScoreAtCheckIn', 'createdAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.date is string
          && checkInId == request.resource.data.date + '_' + request.auth.uid
          && request.resource.data.dailyScoreAtCheckIn is number
          && request.resource.data.dailyScoreAtCheckIn >= 1;
        allow delete: if false;
      }

      match /nudges/{nudgeId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.keys().hasOnly(['fromUid', 'message', 'createdAt'])
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.message in ['Still time today.', 'Get one done.', 'lockin.'];
        allow update, delete: if false;
      }
    }

    /* ── Friendships (pair document id = sorted uid_a_uid_b) ── */
    match /friendships/{pairDocId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if validPendingInviteWrite(pairDocId);

      allow update: if signedIn() && request.auth.uid in resource.data.memberIds
        && request.resource.data.memberIds == resource.data.memberIds
        && (
          (
            request.resource.data.invitedBy == resource.data.invitedBy
            && (
              (resource.data.status == 'pending'
                && request.auth.uid != resource.data.invitedBy
                && request.resource.data.status in ['active', 'declined'])
              || (resource.data.status == 'pending'
                && request.auth.uid == resource.data.invitedBy
                && request.resource.data.status == 'declined')
              || (resource.data.status == 'active'
                && request.resource.data.status == 'ended')
            )
          )
          || (
            resource.data.status in ['declined', 'ended']
            && validPendingInviteWrite(pairDocId)
          )
        );

      allow delete: if false;
    }

    /* ── User-owned private data ───────────────────────── */
    match /users/{uid} {
      allow read, write: if isSelf(uid);

      match /mvpHabits/{habitId} {
        allow read, write: if isSelf(uid);
      }

      match /habits/{habitId} {
        allow read, write: if isSelf(uid);
      }

      match /habitLogs/{dateId} {
        allow read, write: if isSelf(uid);
      }

      match /goals/{goalId} {
        allow read, write: if isSelf(uid);
      }

      match /journal/{dateId} {
        allow read, write: if isSelf(uid);
      }

      match /focusLogs/{dateId} {
        allow read, write: if isSelf(uid);
      }

      match /identity/{docId} {
        allow read, write: if isSelf(uid);
      }

      match /nutritionTargets/{docId} {
        allow read, write: if isSelf(uid);
      }

      match /nutritionIntake/{dateId} {
        allow read, write: if isSelf(uid);
      }

      /* Fitness modules (e.g. bodybuilding branch + nested logs) */
      match /fitness/{branchId} {
        allow read, write: if isSelf(uid);

        match /workouts/{workoutId} {
          allow read, write: if isSelf(uid);
        }

        match /macroLogs/{logId} {
          allow read, write: if isSelf(uid);
        }

        match /goals/{goalId} {
          allow read, write: if isSelf(uid);
        }
      }

      match /settings/{docId} {
        allow read, write: if isSelf(uid);
      }

      /* Sender-only email invite log (MVP; no server email→UID resolution) */
      match /friendInviteOutbox/{docId} {
        allow read, write: if isSelf(uid);
      }

      /* Optional denormalized profile for discovery later */
      match /publicProfile/{docId} {
        allow read: if signedIn();
        allow write: if isSelf(uid);
      }

      /* Friend-visible summary when opted in + active friendship */
      match /shared/{docId} {
        allow write: if isSelf(uid);
        allow read: if signedIn() && (
          isSelf(uid)
          || (
            resource.data.shareEnabled == true
            && friendshipActiveWith(uid)
          )
        );
      }
    }
  }
}
